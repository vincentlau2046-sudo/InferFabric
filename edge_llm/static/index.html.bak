<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>EdgeLLM Dashboard</title>
<style>
:root {
  --bg: #0b0c10; --surface: #13151d; --surface2: #1a1d28; --border: #262936;
  --green: #10b981; --amber: #f59e0b; --red: #ef4444; --blue: #3b82f6; --purple: #a855f7;
  --text: #e2e8f0; --muted: #64748b; --dim: #3b3f52;
}
* { margin:0; padding:0; box-sizing:border-box; }
body {
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Segoe UI', sans-serif;
  background: var(--bg); color: var(--text); min-height: 100vh; padding: 0;
}

/* ── Header ── */
.header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20px 28px; border-bottom: 1px solid var(--border);
  background: var(--surface);
}
.header-left { display: flex; align-items: center; gap: 14px; }
.logo {
  font-size: 18px; font-weight: 800; letter-spacing: -0.5px;
  background: linear-gradient(135deg, var(--blue), var(--purple));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
}
.header-right { display: flex; align-items: center; gap: 16px; }

/* Toggle switch */
.toggle-label { font-size: 11px; color: var(--muted); display:flex;align-items:center;gap:8px;cursor:pointer; }
.toggle {
  width: 36px; height: 20px; border-radius: 10px;
  background: var(--dim); position: relative; transition: background 0.2s; cursor: pointer;
}
.toggle.on { background: var(--blue); }
.toggle::after {
  content:''; position:absolute; top:3px; left:3px;
  width:14px; height:14px; border-radius:50%;
  background:#fff; transition: transform 0.2s;
}
.toggle.on::after { transform: translateX(16px); }

/* Status badge */
.badge {
  padding: 5px 12px; border-radius: 16px;
  font-size: 11px; font-weight: 600; letter-spacing: 0.02em;
}
.badge.active { background: rgba(16,185,129,0.12); color: var(--green); border: 1px solid rgba(16,185,129,0.2); }
.badge.idle { background: rgba(100,116,139,0.12); color: var(--muted); border: 1px solid rgba(100,116,139,0.2); }
.badge.switching { background: rgba(245,158,11,0.12); color: var(--amber); border: 1px solid rgba(245,158,11,0.2); animation: pulse 1s infinite; }
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.5} }

/* ── Main Grid ── */
.container { padding: 24px 28px; max-width: 1200px; margin: 0 auto; }
.section { margin-bottom: 28px; }
.section-title {
  font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em;
  color: var(--muted); margin-bottom: 14px; font-weight: 600;
}

/* ── Metrics Row ── */
.metrics { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; }
@media (max-width: 900px) { .metrics { grid-template-columns: repeat(2, 1fr); } }
.metric {
  background: var(--surface); border: 1px solid var(--border);
  border-radius: 12px; padding: 16px; position: relative; overflow: hidden;
}
.metric-label { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px; }
.metric-value { font-size: 26px; font-weight: 700; line-height: 1; margin-bottom: 4px; }
.metric-unit { font-size: 12px; color: var(--muted); font-weight: 400; }
.metric-bar {
  height: 4px; background: var(--border); border-radius: 2px;
  margin-top: 12px; overflow: hidden;
}
.metric-fill { height: 100%; border-radius: 2px; transition: width 0.5s ease, background 0.3s ease; }
.metric-icon {
  position: absolute; top: 16px; right: 16px;
  font-size: 18px; opacity: 0.3;
}

/* ── Profile List ── */
.profile-list { display: flex; flex-direction: column; gap: 8px; }
.profile-item {
  display: flex; align-items: center; gap: 16px;
  background: var(--surface); border: 1px solid var(--border);
  border-radius: 12px; padding: 16px 20px; cursor: pointer;
  transition: all 0.2s;
}
.profile-item:hover { border-color: var(--blue); transform: translateX(4px); }
.profile-item.active { border-color: var(--green); background: rgba(16,185,129,0.03); }
.profile-item.switching { opacity: 0.5; pointer-events: none; }
.profile-icon {
  width: 40px; height: 40px; border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 16px; font-weight: 700;
}
.profile-info { flex: 1; }
.profile-name { font-size: 14px; font-weight: 600; margin-bottom: 3px; }
.profile-desc { font-size: 12px; color: var(--muted); }
.profile-meta { display: flex; gap: 12px; align-items: center; }
.profile-cost { font-size: 11px; color: var(--amber); }
.profile-services { display: flex; gap: 6px; }
.pill {
  padding: 2px 8px; border-radius: 6px; font-size: 10px; font-weight: 500;
}
.pill.vllm { background: rgba(59,130,246,0.1); color: var(--blue); }
.pill.comfyui { background: rgba(168,85,247,0.1); color: var(--purple); }
.pill.active-pill { background: rgba(16,185,129,0.15); color: var(--green); }

/* ── History ── */
.history { margin-top: 28px; }
.history-list { max-height: 240px; overflow-y: auto; display: flex; flex-direction: column; gap: 6px; }
.history-item {
  display: flex; align-items: center; gap: 10px;
  padding: 10px 14px; background: var(--surface);
  border: 1px solid var(--border); border-radius: 8px; font-size: 12px;
}
.history-from { color: var(--red); }
.history-arrow { color: var(--muted); }
.history-to { color: var(--green); font-weight: 600; }
.history-time { margin-left: auto; color: var(--muted); font-size: 11px; }
.history-dur { margin-left: auto; color: var(--amber); font-size: 11px; }

/* ── Toast ── */
.toast {
  position: fixed; bottom: 24px; right: 24px;
  padding: 12px 20px; border-radius: 10px;
  font-size: 13px; font-weight: 500; z-index: 100;
  transform: translateY(100px); opacity: 0;
  transition: all 0.3s cubic-bezier(0.16,1,0.3,1);
  backdrop-filter: blur(12px);
}
.toast.show { transform: translateY(0); opacity: 1; }
.toast.ok { background: rgba(16,185,129,0.15); border: 1px solid rgba(16,185,129,0.3); color: var(--green); }
.toast.err { background: rgba(239,68,68,0.15); border: 1px solid rgba(239,68,68,0.3); color: var(--red); }
.toast.info { background: rgba(59,130,246,0.15); border: 1px solid rgba(59,130,246,0.3); color: var(--blue); }

/* ── Scrollbar ── */
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }
</style>
</head>
<body>

<div class="header">
  <div class="header-left">
    <span class="logo">EdgeLLM</span>
    <span class="badge idle" id="badge">—</span>
  </div>
  <div class="header-right">
    <label class="toggle-label">
      自动刷新
      <div class="toggle on" id="refreshToggle" onclick="toggleRefresh()"></div>
    </label>
    <span style="font-size:11px;color:var(--muted)" id="lastUpdate">—</span>
  </div>
</div>

<div class="container">

  <!-- Metrics -->
  <div class="section">
    <div class="section-title">系统状态</div>
    <div class="metrics">
      <div class="metric">
        <div class="metric-icon">🧠</div>
        <div class="metric-label">GPU 显存</div>
        <div class="metric-value" id="gpuVal">—<span class="metric-unit"> MB</span></div>
        <div class="metric-bar"><div class="metric-fill" id="gpuFill" style="width:0%;background:var(--green)"></div></div>
        <div style="font-size:11px;color:var(--muted);margin-top:6px" id="gpuPct">—</div>
      </div>
      <div class="metric">
        <div class="metric-icon">💾</div>
        <div class="metric-label">系统内存</div>
        <div class="metric-value" id="ramVal">—<span class="metric-unit"> GB</span></div>
        <div class="metric-bar"><div class="metric-fill" id="ramFill" style="width:0%;background:var(--blue)"></div></div>
        <div style="font-size:11px;color:var(--muted);margin-top:6px" id="ramPct">—</div>
      </div>
      <div class="metric">
        <div class="metric-icon">⚡</div>
        <div class="metric-label">CPU 负载</div>
        <div class="metric-value" id="cpuVal">—<span class="metric-unit"> %</span></div>
        <div class="metric-bar"><div class="metric-fill" id="cpuFill" style="width:0%;background:var(--amber)"></div></div>
        <div style="font-size:11px;color:var(--muted);margin-top:6px" id="cpuCore">—</div>
      </div>
      <div class="metric">
        <div class="metric-icon">⏱️</div>
        <div class="metric-label">运行时间</div>
        <div class="metric-value" id="uptimeVal">—<span class="metric-unit"></span></div>
        <div style="font-size:11px;color:var(--muted);margin-top:12px" id="lastSwitch">—</div>
      </div>
    </div>
  </div>

  <!-- Service Health -->
  <div class="section">
    <div class="section-title">服务健康</div>
    <div style="display:flex;gap:10px;flex-wrap:wrap">
      <div class="pill" id="vllmHealth" style="font-size:12px;padding:6px 14px">vLLM: —</div>
      <div class="pill" id="comfyuiHealth" style="font-size:12px;padding:6px 14px">ComfyUI: —</div>
      <div class="pill" id="proxyHealth" style="font-size:12px;padding:6px 14px;color:var(--green);background:rgba(16,185,129,0.1)">Proxy: ✅</div>
    </div>
  </div>

  <!-- Profile List -->
  <div class="section">
    <div class="section-title">模型配置</div>
    <div class="profile-list" id="profileList"></div>
  </div>

  <!-- History -->
  <div class="history">
    <div class="section-title">切换历史</div>
    <div class="history-list" id="historyList">
      <div style="padding:14px;color:var(--muted);font-size:12px">暂无数据</div>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
// Auto-detect API base: if served from :8999 use relative, otherwise use proxy URL
const proxyHost = window.location.hostname;
const proxyPort = window.location.port;
let API = '';
if (proxyPort !== '8999') {
  API = 'http://' + proxyHost + ':8999';
}
let autoRefresh = true;
let refreshInterval;

function toggleRefresh() {
  autoRefresh = !autoRefresh;
  document.getElementById('refreshToggle').className = 'toggle' + (autoRefresh ? ' on' : '');
  if (autoRefresh) startRefresh(); else stopRefresh();
}

function startRefresh() { refreshInterval = setInterval(refresh, 5000); }
function stopRefresh() { clearInterval(refreshInterval); }

function toast(msg, type='info', dur=3000) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.className = 'toast show ' + type;
  setTimeout(() => t.className = 'toast', dur);
}

async function get(path) {
  const r = await fetch(API + path, {cache: 'no-store'});
  return r.json();
}

function colorFor(pct) {
  if (pct < 50) return 'var(--green)';
  if (pct < 80) return 'var(--amber)';
  return 'var(--red)';
}

async function updateMetrics() {
  try {
    const s = await get('/status');
    const badge = document.getElementById('badge');
    const profile = s.profile;
    badge.textContent = profile.toUpperCase();
    badge.className = 'badge ' + (profile === 'idle' ? 'idle' : 'active');

    // GPU
    const used = s.gpu_used_mb || 0;
    const total = 32607;
    const gp = (used / total * 100).toFixed(1);
    document.getElementById('gpuVal').innerHTML = used.toLocaleString() + '<span class="metric-unit"> MB</span>';
    document.getElementById('gpuPct').textContent = gp + '% 已用';
    const gf = document.getElementById('gpuFill');
    gf.style.width = gp + '%'; gf.style.background = colorFor(gp);

    // Services
    const v = document.getElementById('vllmHealth');
    v.textContent = 'vLLM: ' + (s.vllm || '—');
    v.className = 'pill' + (s.vllm === '✅' ? ' active-pill' : '');

    const c = document.getElementById('comfyuiHealth');
    c.textContent = 'ComfyUI: ' + (s.comfyui || '—');
    c.className = 'pill' + (s.comfyui === '✅' ? ' active-pill' : '');

    // Last switch
    if (s.last_switch) document.getElementById('lastSwitch').textContent = '上次切换: ' + s.last_switch;

  } catch(e) {
    document.getElementById('badge').textContent = 'ERROR';
    document.getElementById('badge').className = 'badge idle';
  }
}

async function updateSystemMetrics() {
  try {
    const sys = await get('/system');
    // RAM
    const ramTotal = sys.ram_total_gb || 1;
    const ramUsed = sys.ram_used_gb || 0;
    const rp = (ramUsed / ramTotal * 100).toFixed(1);
    document.getElementById('ramVal').innerHTML = ramUsed.toFixed(1) + '<span class="metric-unit"> GB</span>';
    document.getElementById('ramPct').textContent = rp + '% 已用';
    const rf = document.getElementById('ramFill');
    rf.style.width = rp + '%'; rf.style.background = colorFor(rp);

    // CPU
    const cp = sys.cpu_percent || 0;
    document.getElementById('cpuVal').innerHTML = cp.toFixed(1) + '<span class="metric-unit"> %</span>';
    document.getElementById('cpuCore').textContent = sys.cpu_cores + ' 核';
    const cf = document.getElementById('cpuFill');
    cf.style.width = cp + '%'; cf.style.background = colorFor(cp);

    // Uptime
    const up = sys.uptime_seconds || 0;
    const hrs = Math.floor(up / 3600);
    const mins = Math.floor((up % 3600) / 60);
    document.getElementById('uptimeVal').innerHTML = hrs + 'h ' + mins + 'm<span class="metric-unit"></span>';
  } catch(e) {
    // /system endpoint may not exist yet; graceful fallback
  }
}

const PROFILE_ICONS = {
  qw36_full: 'Q', qw35_comfyui: 'Q', gemma_full: 'G',
  comfyui_only: 'C', idle: '⊘'
};
const PROFILE_COLORS = {
  qw36_full: 'var(--blue)', qw35_comfyui: 'var(--purple)',
  gemma_full: 'var(--amber)', comfyui_only: 'var(--purple)', idle: 'var(--dim)'
};

async function updateProfiles() {
  const profiles = await get('/profiles');
  const list = document.getElementById('profileList');
  list.innerHTML = '';
  for (const p of profiles) {
    const item = document.createElement('div');
    item.className = 'profile-item' + (p.current ? ' active' : '');
    item.id = 'prof-' + p.name;
    const icon = PROFILE_ICONS[p.name] || '?';
    const color = PROFILE_COLORS[p.name] || 'var(--muted)';
    const services = [];
    if (p.has_vllm) services.push('<span class="pill vllm">vLLM</span>');
    if (p.has_comfyui) services.push('<span class="pill comfyui">ComfyUI</span>');
    item.innerHTML =
      '<div class="profile-icon" style="background:' + color + '18;color:' + color + '">' + icon + '</div>' +
      '<div class="profile-info">' +
        '<div class="profile-name">' + p.name + '</div>' +
        '<div class="profile-desc">' + p.description + '</div>' +
      '</div>' +
      '<div class="profile-meta">' +
        '<div class="profile-services">' + services.join('') + '</div>' +
        '<span class="profile-cost">~' + p.switch_cost_sec + 's</span>' +
      '</div>';
    item.onclick = () => doSwitch(p.name);
    list.appendChild(item);
  }
}

async function doSwitch(name) {
  document.querySelectorAll('.profile-item').forEach(el => el.classList.add('switching'));
  document.getElementById('badge').textContent = 'SWITCHING';
  document.getElementById('badge').className = 'badge switching';
  toast('正在切换到 ' + name + '...', 'info', 5000);

  try {
    const r = await fetch(API + '/switch', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({profile: name})
    });
    const result = await r.json();

    if (result.status === 'switched') {
      toast('✅ 已切换到 ' + name + ' (' + result.elapsed_sec + 's)', 'ok');
    } else if (result.status === 'already_active') {
      toast('ℹ️ 已在 ' + name + ' 上', 'info');
    } else {
      toast('❌ ' + (result.message || '切换失败'), 'err');
    }
  } catch(e) {
    toast('❌ ' + e.message, 'err');
  }

  await updateMetrics();
  await updateProfiles();
}

async function refresh() {
  await updateMetrics();
  await updateSystemMetrics();
  await updateProfiles();
  document.getElementById('lastUpdate').textContent = new Date().toLocaleTimeString();
}

refresh();
startRefresh();
</script>
</body>
</html>
